{
  "rules": {
    "profiles": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid",
        "is_admin": {
          ".write": false
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "credits": {
          ".write": "auth != null && (auth.uid === $uid || root.child('profiles').child(auth.uid).child('is_admin').val() === true)"
        },
        "usage": {
          "$toolId": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },
    "app_settings": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('profiles').child(auth.uid).child('is_admin').val() === true"
    }
  }
}
